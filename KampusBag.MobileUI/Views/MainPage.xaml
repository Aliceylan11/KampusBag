<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KampusBag.MobileUI.Views.MainPage"
             BackgroundColor="#1B305E"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*, Auto" Padding="30">

        <!-- ÜST: Logo ve Karşılama Alanı -->
        <VerticalStackLayout Grid.Row="0"
                             VerticalOptions="Center"
                             Spacing="0">

            <!-- Logo Çemberi -->
            <Frame WidthRequest="110"
                   HeightRequest="110"
                   CornerRadius="55"
                   Padding="0"
                   BackgroundColor="#FFF"
                   BorderColor="#FFF"
                   HorizontalOptions="Center"
                   Margin="0,0,0,24">
                <Label Text="🎒"
                       FontSize="52"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Frame>

            <!-- Uygulama Adı -->
            <Label Text="KampusBag"
                   FontSize="40"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   Margin="0,0,0,8" />

            <!-- Slogan -->
            <Label Text="Kampüsün Güvenli İletişim Ağı"
                   FontSize="15"
                   TextColor="#A8BDD9"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,40" />

            <!-- Ayırıcı çizgi -->
            <BoxView HeightRequest="1"
                     Color="#FFF"
                     Margin="20,0,20,40" />

            <!-- Özellik listesi -->
            <VerticalStackLayout Spacing="14" Margin="10,0">

                <HorizontalStackLayout Spacing="12">
                    <Frame WidthRequest="36" HeightRequest="36" CornerRadius="8"
                           Padding="0" BackgroundColor="#FFF" BorderColor="Transparent">
                        <Label Text="🔒" FontSize="18"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Frame>
                    <Label Text="Kurumsal e-posta ile güvenli kayıt"
                           TextColor="#C8D8EC" VerticalOptions="Center" FontSize="14"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="12">
                    <Frame WidthRequest="36" HeightRequest="36" CornerRadius="8"
                           Padding="0" BackgroundColor="#FFF" BorderColor="Transparent">
                        <Label Text="📚" FontSize="18"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Frame>
                    <Label Text="Ders grupları ve acil mesajlaşma"
                           TextColor="#C8D8EC" VerticalOptions="Center" FontSize="14"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="12">
                    <Frame WidthRequest="36" HeightRequest="36" CornerRadius="8"
                           Padding="0" BackgroundColor="#FFF" BorderColor="Transparent">
                        <Label Text="🚨" FontSize="18"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Frame>
                    <Label Text="Dönemlik 3 acil durum mesaj hakkı"
                           TextColor="#C8D8EC" VerticalOptions="Center" FontSize="14"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>

        </VerticalStackLayout>

        <!-- ALT: Aksiyon Butonları -->
        <VerticalStackLayout Grid.Row="1"
                             Spacing="12"
                             Margin="0,0,0,44">

            <!-- Giriş Yap Butonu -->
            <Button Text="🚀  Giriş Yap"
                    BackgroundColor="White"
                    TextColor="#1B305E"
                    CornerRadius="14"
                    HeightRequest="56"
                    FontAttributes="Bold"
                    FontSize="16"
                    Clicked="OnLoginClicked" />

            <!-- Kayıt Ol Butonu -->
            <Button Text="Hesabın yok mu?  Kayıt Ol →"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    BorderColor="#FFF"
                    BorderWidth="1.5"
                    CornerRadius="14"
                    HeightRequest="56"
                    FontSize="15"
                    Clicked="OnRegisterClicked" />

            <!-- Versiyon -->
            <Label Text="v1.0.0 Beta  ·  Gümüşhane Üniversitesi"
                   FontSize="11"
                   TextColor="#5A7A9A"
                   HorizontalOptions="Center"
                   Margin="0,6,0,0" />

        </VerticalStackLayout>
    </Grid>
</ContentPage>
