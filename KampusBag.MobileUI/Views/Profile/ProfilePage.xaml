<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KampusBag.MobileUI.Views.Profile.ProfilePage"
             Title="Profilim"
             BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#111827}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ÜST BANNER: Lacivert arka plan -->
            <Grid BackgroundColor="#1B305E"
                  Padding="28,40,28,60">
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">

                    <!-- Avatar Çemberi: Baş Harf -->
                    <Frame WidthRequest="90" HeightRequest="90"
                           CornerRadius="45" Padding="0"
                           BackgroundColor="#FFF"
                           BorderColor="#FFF"
                           HorizontalOptions="Center">
                        <Label x:Name="AvatarLabel"
                               Text="?"
                               FontSize="36"
                               FontAttributes="Bold"
                               TextColor="Black"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Frame>

                    <!-- Ad Soyad -->
                    <Label x:Name="FullNameLabel"
                           Text="Yükleniyor..."
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"/>

                    <!-- Rol Badge -->
                    <Frame x:Name="RoleBadge"
                           Padding="14,5"
                           CornerRadius="20"
                           BackgroundColor="#FFF"
                           BorderColor="#FFF"
                           HorizontalOptions="Center">
                        <Label x:Name="RoleLabel"
                               Text="Öğrenci"
                               FontSize="13"
                               TextColor="Black"
                               HorizontalOptions="Center"/>
                    </Frame>

                </VerticalStackLayout>
            </Grid>

            <!-- İSTATİSTİK KARTI - Banner'a bindirme efekti -->
            <Frame BackgroundColor="{AppThemeBinding Light=White, Dark=#1F2937}"
                   BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                   CornerRadius="16"
                   Padding="0"
                   Margin="20,-28,20,0"
                   HasShadow="True">
                <Grid ColumnDefinitions="*, Auto, *, Auto, *">

                    <!-- Derslerim -->
                    <VerticalStackLayout Grid.Column="0" Spacing="4"
                                        Padding="12,18" HorizontalOptions="Center">
                        <Label Text="7"
                               FontSize="26" FontAttributes="Bold"
                               TextColor="#1B305E" HorizontalOptions="Center"/>
                        <Label Text="Ders"
                               FontSize="12" TextColor="#6B7280"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <BoxView Grid.Column="1" WidthRequest="1"
                             Color="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                             VerticalOptions="Fill" Margin="0,12"/>

                    <!-- Mesajlarım -->
                    <VerticalStackLayout Grid.Column="2" Spacing="4"
                                        Padding="12,18" HorizontalOptions="Center">
                        <Label Text="42"
                               FontSize="26" FontAttributes="Bold"
                               TextColor="#1B305E" HorizontalOptions="Center"/>
                        <Label Text="Mesaj"
                               FontSize="12" TextColor="#6B7280"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <BoxView Grid.Column="3" WidthRequest="1"
                             Color="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                             VerticalOptions="Fill" Margin="0,12"/>

                    <!-- Acil Hak -->
                    <VerticalStackLayout Grid.Column="4" Spacing="4"
                                        Padding="12,18" HorizontalOptions="Center">
                        <Label x:Name="EmergencyRightsLabel"
                               Text="3"
                               FontSize="26" FontAttributes="Bold"
                               TextColor="#D32F2F" HorizontalOptions="Center"/>
                        <Label Text="Acil Hak"
                               FontSize="12" TextColor="#6B7280"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                </Grid>
            </Frame>

            <!-- BİLGİ KARTI -->
            <Frame BackgroundColor="{AppThemeBinding Light=White, Dark=#1F2937}"
                   BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                   CornerRadius="16"
                   Padding="20"
                   Margin="20,16,20,0">
                <VerticalStackLayout Spacing="0">

                    <Label Text="Hesap Bilgileri"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="#6B7280"
                           Margin="0,0,0,14"/>

                    <!-- E-posta -->
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="14"
                          Padding="0,10" >
                        <Frame Grid.Column="0" WidthRequest="38" HeightRequest="38"
                               CornerRadius="8" Padding="0"
                               BackgroundColor="#EFF6FF" BorderColor="Transparent">
                            <Label Text="📧" FontSize="18"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="E-posta" FontSize="11" TextColor="#9CA3AF"/>
                            <Label x:Name="EmailLabel"
                                   Text="—"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light=#111827, Dark=White}"
                                   FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light=#F3F4F6, Dark=#374151}"
                             Margin="0,2"/>

                    <!-- Öğrenci / Sicil No -->
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="14"
                          Padding="0,10">
                        <Frame Grid.Column="0" WidthRequest="38" HeightRequest="38"
                               CornerRadius="8" Padding="0"
                               BackgroundColor="#F0FDF4" BorderColor="Transparent">
                            <Label Text="🔢" FontSize="18"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label x:Name="RegistrationLabel"
                                   Text="Öğrenci No" FontSize="11" TextColor="#9CA3AF"/>
                            <Label x:Name="RegistrationNumberLabel"
                                   Text="—"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light=#111827, Dark=White}"
                                   FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light=#F3F4F6, Dark=#374151}"
                             Margin="0,2"/>

                    <!-- Rol -->
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="14"
                          Padding="0,10">
                        <Frame Grid.Column="0" WidthRequest="38" HeightRequest="38"
                               CornerRadius="8" Padding="0"
                               BackgroundColor="#FEF3C7" BorderColor="Transparent">
                            <Label Text="🎓" FontSize="18"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Rol" FontSize="11" TextColor="#9CA3AF"/>
                            <Label x:Name="RoleDetailLabel"
                                   Text="—"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light=#111827, Dark=White}"
                                   FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <!-- AYARLAR KARTI -->
            <Frame BackgroundColor="{AppThemeBinding Light=White, Dark=#1F2937}"
                   BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                   CornerRadius="16"
                   Padding="20"
                   Margin="20,12,20,0">
                <VerticalStackLayout Spacing="0">

                    <Label Text="Ayarlar"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="#6B7280"
                           Margin="0,0,0,14"/>

                    <!-- Karanlık Mod -->
                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="14">
                        <Frame Grid.Column="0" WidthRequest="38" HeightRequest="38"
                               CornerRadius="8" Padding="0"
                               BackgroundColor="#F3F0FF" BorderColor="Transparent">
                            <Label Text="🌙" FontSize="18"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Frame>
                        <Label Grid.Column="1" Text="Karanlık Mod"
                               FontSize="15"
                               TextColor="{AppThemeBinding Light=#111827, Dark=White}"
                               VerticalOptions="Center"/>
                        <Switch Grid.Column="2"
                                x:Name="DarkModeSwitch"
                                Toggled="OnDarkModeToggled"
                                VerticalOptions="Center"/>
                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <!-- ÇIKIŞ BUTONU -->
            <Frame BackgroundColor="{AppThemeBinding Light=White, Dark=#1F2937}"
                   BorderColor="{AppThemeBinding Light=#FEE2E2, Dark=#7F1D1D}"
                   CornerRadius="16"
                   Padding="0"
                   Margin="20,12,20,32">
                <Button Text="🚪  Güvenli Çıkış Yap"
                        Clicked="OnLogoutClicked"
                        BackgroundColor="Transparent"
                        TextColor="#DC2626"
                        FontAttributes="Bold"
                        FontSize="15"
                        HeightRequest="58"
                        HorizontalOptions="Fill" />
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
