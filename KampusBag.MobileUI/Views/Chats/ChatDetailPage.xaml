<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KampusBag.MobileUI.Views.Chats.ChatDetailPage"
             Title="Sohbet">

    <Grid RowDefinitions="*, Auto">

        <CollectionView Grid.Row="0" x:Name="MessagesList" Margin="15">
            
        </CollectionView>

        <Border Grid.Row="1" StrokeThickness="0" BackgroundColor="White" Padding="10">
            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">

                <Button x:Name="EmergencyButton"
                        Grid.Column="0"
                        Text="🚨"
                        BackgroundColor="#D32F2F"
                        WidthRequest="45" HeightRequest="45"
                        CornerRadius="22"
                        IsVisible="False"
                        Clicked="OnEmergencyClicked" />

                <Entry x:Name="MessageEntry"
                       Grid.Column="1" 
                       Placeholder="Mesajınızı yazın..." 
                       PlaceholderColor="Gray"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" 
                       BackgroundColor="{AppThemeBinding Light=#F0F2F5, Dark=#333333}"
                       HeightRequest="45" />

                <Button Grid.Column="2"
                        Text="➤"
                        BackgroundColor="#1B305E"
                        WidthRequest="45" HeightRequest="45"
                        CornerRadius="22"
                        Clicked="OnSendMessageClicked" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>