<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KampusBag.MobileUI.Views.Chats.JoinCoursePage"
             BackgroundColor="#80000000">
    <Frame VerticalOptions="Center" 
           HorizontalOptions="Center" 
           Margin="30" 
           Padding="25"
           CornerRadius="20" 
           BackgroundColor="White"
           HasShadow="True"
           WidthRequest="320">

        <VerticalStackLayout Spacing="20">

            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                <Label Text="Derse Katıl" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       TextColor="#1B305E" 
                       HorizontalOptions="Center" />
                <Label Text="Hocanızdan aldığınız 6 haneli kodu girin." 
                       FontSize="13" 
                       TextColor="Gray" 
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Frame Padding="0" CornerRadius="10" BorderColor="#E0E0E0">
                <Entry x:Name="CourseCodeEntry"
                       Placeholder="Örn: KB1234" 
                       MaxLength="6"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       CharacterSpacing="5"
                       HeightRequest="55" />
            </Frame>

            <VerticalStackLayout Spacing="10">
                <Button Text="Gruba Dahil Ol" 
                        BackgroundColor="#1B305E" 
                        TextColor="White" 
                        CornerRadius="10" 
                        HeightRequest="50" 
                        FontAttributes="Bold"
                        Clicked="OnJoinClicked" />

                <Button Text="Vazgeç" 
                        BackgroundColor="Transparent" 
                        TextColor="Gray" 
                        FontSize="14"
                        Clicked="OnCancelClicked" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </Frame>
</ContentPage>