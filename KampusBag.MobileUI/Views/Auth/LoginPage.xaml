<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KampusBag.MobileUI.Views.Auth.LoginPage"
             BackgroundColor="White"
             Title="Giriş">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">

            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                <Image Source="kampusbag_logo.png" 
                       HeightRequest="100" 
                       HorizontalOptions="Center" />
                <Label Text="Tekrar Hoş Geldin" 
                       FontSize="28" 
                       FontAttributes="Bold" 
                       TextColor="#1B305E" 
                       HorizontalOptions="Center" />
                <Label Text="Hesabına erişim sağla" 
                       FontSize="14" 
                       TextColor="Gray" 
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="15">

                <Frame Padding="0" CornerRadius="10" BorderColor="#E0E0E0">
                    <Entry x:Name="IdentifierEntry"
                           Placeholder="Öğrenci No / Email" 
                           Keyboard="Email"
                           HeightRequest="50" 
                           Margin="10,0" />
                </Frame>

                <VerticalStackLayout Spacing="5">
                    <Frame Padding="0" CornerRadius="10" BorderColor="#E0E0E0">
                        <Entry x:Name="PasswordEntry"
                               Placeholder="Şifre" 
                               IsPassword="True" 
                               HeightRequest="50" 
                               Margin="10,0" />
                    </Frame>

                    <Button Text="Şifremi Unuttum" 
                            TextColor="#1B305E" 
                            BackgroundColor="Transparent" 
                            FontSize="12" 
                            HorizontalOptions="End"
                            Clicked="OnForgotPasswordClicked"/>
                </VerticalStackLayout>

            </VerticalStackLayout>

            <Button Text="Giriş Yap" 
                    BackgroundColor="#1B305E" 
                    TextColor="White" 
                    CornerRadius="10" 
                    HeightRequest="55" 
                    FontAttributes="Bold"
                    Clicked="OnLoginSubmitClicked" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="Henüz hesabın yok mu?" VerticalOptions="Center"/>
                <Button Text="Kayıt Ol" 
                        TextColor="#1B305E" 
                        BackgroundColor="Transparent" 
                        FontAttributes="Bold"
                        Clicked="OnRegisterClicked"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>