<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KampusBag.MobileUI.Views.Auth.LoginPage"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#121212}"
             Title="Giriş">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="28" VerticalOptions="Center">

            <!-- Başlık Alanı -->
            <VerticalStackLayout Spacing="6" Margin="0,0,0,36">
                <Label Text="👋"
                       FontSize="44"
                       HorizontalOptions="Start"
                       Margin="0,0,0,4"/>
                <Label Text="Tekrar Hoş Geldin"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#1B305E, Dark=#6FA8FF}" />
                <Label Text="Hesabına güvenle giriş yap"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
            </VerticalStackLayout>

            <!-- Form Alanı -->
            <VerticalStackLayout Spacing="14">

                <!-- Identifier -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Öğrenci No veya E-posta"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"
                           Margin="4,0"/>
                    <Frame Padding="0" CornerRadius="12"
                           BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                           BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#1F2937}">
                        <Entry x:Name="IdentifierEntry"
                               Placeholder="2411081054 veya ad@ogr.gumushane.edu.tr"
                               Keyboard="Email"
                               TextColor="{AppThemeBinding Light=#111827, Dark=White}"
                               PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}"
                               BackgroundColor="Transparent"
                               HeightRequest="52"
                               Margin="14,0" />
                    </Frame>
                </VerticalStackLayout>

                <!-- Şifre -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Şifre"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"
                           Margin="4,0"/>
                    <Frame Padding="0" CornerRadius="12"
                           BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                           BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#1F2937}">
                        <Entry x:Name="PasswordEntry"
                               Placeholder="Şifrenizi girin"
                               IsPassword="True"
                               TextColor="{AppThemeBinding Light=#111827, Dark=White}"
                               PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}"
                               BackgroundColor="Transparent"
                               HeightRequest="52"
                               Margin="14,0" />
                    </Frame>
                </VerticalStackLayout>

                <!-- Şifremi Unuttum -->
                <Button Text="Şifremi Unuttum"
                        TextColor="#1B305E"
                        BackgroundColor="Transparent"
                        FontSize="13"
                        FontAttributes="Bold"
                        HorizontalOptions="End"
                        Margin="0,-4,0,0"
                        Clicked="OnForgotPasswordClicked"/>

            </VerticalStackLayout>

            <!-- Giriş Butonu -->
            <Button x:Name="LoginButton"
                    Text="Giriş Yap"
                    BackgroundColor="#1B305E"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="56"
                    FontAttributes="Bold"
                    FontSize="16"
                    Margin="0,24,0,0"
                    Clicked="OnLoginSubmitClicked" />

            <!-- Ayırıcı -->
            <Grid ColumnDefinitions="*, Auto, *" Margin="0,20,0,16">
                <BoxView Grid.Column="0" HeightRequest="1" Color="#E5E7EB" VerticalOptions="Center"/>
                <Label Grid.Column="1" Text="  veya  " TextColor="#9CA3AF" FontSize="13"/>
                <BoxView Grid.Column="2" HeightRequest="1" Color="#E5E7EB" VerticalOptions="Center"/>
            </Grid>

            <!-- Kayıt Ol -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="Henüz hesabın yok mu?"
                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                       VerticalOptions="Center"
                       FontSize="14"/>
                <Button Text="Kayıt Ol"
                        TextColor="#1B305E"
                        BackgroundColor="Transparent"
                        FontAttributes="Bold"
                        FontSize="14"
                        Clicked="OnRegisterClicked"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
