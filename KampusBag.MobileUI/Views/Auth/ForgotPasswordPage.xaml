<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KampusBag.MobileUI.Views.Auth.ForgotPasswordPage"
             Title="Şifremi Unuttum"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">

            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                <Label Text="🔒" FontSize="60" HorizontalOptions="Center" />
                <Label Text="Şifrenizi mi unuttunuz?" FontSize="24" FontAttributes="Bold" TextColor="#1B305E" HorizontalOptions="Center" />
                <Label Text="E-posta adresinize şifre sıfırlama kodu göndereceğiz." FontSize="14" TextColor="Gray" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="15">
                <Label Text="Kurumsal E-posta Adresiniz" FontAttributes="Bold" Margin="5,0"/>
                <Frame Padding="0" CornerRadius="10" BorderColor="#E0E0E0">
                    <!-- x:Name="EmailEntry" C# tarafıyla eşleşmeli -->
                    <Entry x:Name="EmailEntry" Placeholder="ornek@ogr.gumushane.edu.tr" Keyboard="Email" HeightRequest="50" Margin="10,0" />
                </Frame>

            </VerticalStackLayout>

            <Button x:Name="SendCodeButton" Text="Kod Gönder" BackgroundColor="#1B305E" TextColor="White" CornerRadius="10" HeightRequest="55" FontAttributes="Bold" Clicked="OnSendCodeClicked" />

            <Button Text="Giriş Ekranına Dön" TextColor="#1B305E" BackgroundColor="Transparent" Clicked="OnBackToLoginClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
Done