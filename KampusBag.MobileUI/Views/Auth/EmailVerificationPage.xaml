<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KampusBag.MobileUI.Views.Auth.EmailVerificationPage"
             Title="Doğrulama"
             BackgroundColor="White">

    <VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">

        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
            <Label Text="Kodu Onayla" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="#1B305E" 
                   HorizontalOptions="Center" />
            <Label Text="Lütfen kurumsal mail adresinize gelen 6 haneli kodu giriniz." 
                   FontSize="14" 
                   TextColor="Gray" 
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <Frame Padding="0" CornerRadius="10" BorderColor="#E0E0E0" WidthRequest="200" HorizontalOptions="Center">
            <Entry x:Name="OtpEntry"
                   Placeholder="000000" 
                   Keyboard="Numeric" 
                   MaxLength="6"
                   FontSize="24"
                   HorizontalTextAlignment="Center"
                   HeightRequest="60" />
        </Frame>

        <Button Text="Doğrula ve Devam Et" 
                BackgroundColor="#1B305E" 
                TextColor="White" 
                CornerRadius="10" 
                HeightRequest="55" 
                FontAttributes="Bold"
                Clicked="OnVerifyClicked" />

        <Button Text="Kodu Tekrar Gönder" 
                TextColor="#1B305E" 
                BackgroundColor="Transparent" 
                FontSize="14" 
                Clicked="OnResendCodeClicked"/>

    </VerticalStackLayout>
</ContentPage>