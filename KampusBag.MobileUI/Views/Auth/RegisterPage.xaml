<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KampusBag.MobileUI.Views.Auth.RegisterPage"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#121212}"
             Title="Kayıt Ol">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="28" VerticalOptions="Center">

            <!-- Başlık Alanı -->
            <VerticalStackLayout Spacing="6" Margin="0,0,0,30">
                <Label Text="🎓"
                       FontSize="44"
                       HorizontalOptions="Start"
                       Margin="0,0,0,4"/>
                <Label Text="Aramıza Katıl"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#1B305E, Dark=#6FA8FF}" />
                <Label Text="Kurumsal e-postanla hesap oluştur"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
            </VerticalStackLayout>

            <!-- Form Alanları -->
            <VerticalStackLayout Spacing="14">

                <!-- Ad Soyad -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="👤  Ad Soyad"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"
                           Margin="4,0"/>
                    <Frame Padding="0" CornerRadius="12"
                           BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                           BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#1F2937}">
                        <Entry x:Name="FullNameEntry"
                               Placeholder="Adınız ve soyadınız"
                               TextColor="{AppThemeBinding Light=#111827, Dark=White}"
                               PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}"
                               BackgroundColor="Transparent"
                               HeightRequest="52" Margin="14,0" />
                    </Frame>
                </VerticalStackLayout>

                <!-- Öğrenci No -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="🔢  Öğrenci / Sicil Numarası"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"
                           Margin="4,0"/>
                    <Frame Padding="0" CornerRadius="12"
                           BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                           BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#1F2937}">
                        <Entry x:Name="StudentNumberEntry"
                               Placeholder="2411081054"
                               Keyboard="Numeric"
                               TextColor="{AppThemeBinding Light=#111827, Dark=White}"
                               PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}"
                               BackgroundColor="Transparent"
                               HeightRequest="52" Margin="14,0" />
                    </Frame>
                </VerticalStackLayout>

                <!-- Email -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="📧  Kurumsal E-posta"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"
                           Margin="4,0"/>
                    <Frame Padding="0" CornerRadius="12"
                           BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                           BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#1F2937}">
                        <Entry x:Name="EmailEntry"
                               Placeholder="ad@ogr.gumushane.edu.tr"
                               Keyboard="Email"
                               TextColor="{AppThemeBinding Light=#111827, Dark=White}"
                               PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}"
                               BackgroundColor="Transparent"
                               HeightRequest="52" Margin="14,0" />
                    </Frame>
                </VerticalStackLayout>

                <!-- Şifre -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="🔑  Şifre"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"
                           Margin="4,0"/>
                    <Frame Padding="0" CornerRadius="12"
                           BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                           BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#1F2937}">
                        <Entry x:Name="PasswordEntry"
                               Placeholder="En az 6 karakter"
                               IsPassword="True"
                               TextColor="{AppThemeBinding Light=#111827, Dark=White}"
                               PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}"
                               BackgroundColor="Transparent"
                               HeightRequest="52" Margin="14,0" />
                    </Frame>
                </VerticalStackLayout>

                <!-- Şifre Tekrar -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="🔑  Şifre Tekrar"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"
                           Margin="4,0"/>
                    <Frame Padding="0" CornerRadius="12"
                           BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                           BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#1F2937}">
                        <Entry x:Name="ConfirmPasswordEntry"
                               Placeholder="Şifrenizi tekrar girin"
                               IsPassword="True"
                               TextColor="{AppThemeBinding Light=#111827, Dark=White}"
                               PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}"
                               BackgroundColor="Transparent"
                               HeightRequest="52" Margin="14,0" />
                    </Frame>
                </VerticalStackLayout>

            </VerticalStackLayout>

            <!-- Kayıt Ol Butonu -->
            <Button Text="Hesap Oluştur"
                    Clicked="OnRegisterSubmitClicked"
                    BackgroundColor="#1B305E"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="56"
                    FontAttributes="Bold"
                    FontSize="16"
                    Margin="0,24,0,0" />

            <!-- Bilgi Notu -->
            <Frame BackgroundColor="#EFF6FF"
                   BorderColor="#BFDBFE"
                   CornerRadius="10"
                   Padding="14,10"
                   Margin="0,16,0,0">
                <Label Text="ℹ️  Yalnızca @ogr.gumushane.edu.tr veya @gumushane.edu.tr uzantılı e-postalar kabul edilmektedir."
                       FontSize="12"
                       TextColor="#1D4ED8"
                       HorizontalTextAlignment="Center"/>
            </Frame>

            <!-- Giriş Yap -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,16,0,0">
                <Label Text="Zaten üye misin?"
                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
                       VerticalOptions="Center" FontSize="14"/>
                <Button Text="Giriş Yap"
                        TextColor="#1B305E"
                        BackgroundColor="Transparent"
                        FontAttributes="Bold"
                        FontSize="14"
                        Clicked="OnLoginClicked"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
