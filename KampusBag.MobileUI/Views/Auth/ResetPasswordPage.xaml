<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KampusBag.MobileUI.Views.Auth.ResetPasswordPage"
             Title="Yeni Şifre Oluştur"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">

            <!-- Başlık Bölümü -->
            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                <Label Text="🔑" 
                       FontSize="60" 
                       HorizontalOptions="Center" />

                <Label Text="Şifrenizi Yenileyin" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       TextColor="#1B305E" 
                       HorizontalOptions="Center" />

                <Label Text="E-postanıza gelen 6 haneli kodu ve yeni şifrenizi girin." 
                       FontSize="14" 
                       TextColor="Gray" 
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Giriş Alanları -->
            <VerticalStackLayout Spacing="15">

                <!-- Kod Girişi -->
                <Label Text="Sıfırlama Kodu" FontAttributes="Bold" Margin="5,0"/>
                <Frame Padding="0" CornerRadius="10" BorderColor="#E0E0E0">
                    <Entry x:Name="CodeEntry"
                           Placeholder="6 Haneli Kod" 
                           Keyboard="Numeric"
                           MaxLength="6"
                           HeightRequest="50" 
                           Margin="10,0" />
                </Frame>

                <!-- Yeni Şifre Girişi -->
                <Label Text="Yeni Şifre" FontAttributes="Bold" Margin="5,0"/>
                <Frame Padding="0" CornerRadius="10" BorderColor="#E0E0E0">
                    <Entry x:Name="NewPasswordEntry"
                           Placeholder="••••••" 
                           IsPassword="True"
                           HeightRequest="50" 
                           Margin="10,0" />
                </Frame>

            </VerticalStackLayout>

            <!-- İşlem Butonu -->
            <Button x:Name="ResetButton"
                    Text="Şifreyi Güncelle" 
                    BackgroundColor="#1B305E" 
                    TextColor="White" 
                    CornerRadius="10" 
                    HeightRequest="55" 
                    FontAttributes="Bold"
                    Clicked="OnResetPasswordClicked" />

            <!-- Geri Dönüş -->
            <Button Text="Vazgeç ve Giriş Ekranına Dön" 
                    TextColor="Gray" 
                    BackgroundColor="Transparent" 
                    FontSize="13"
                    Clicked="OnBackToLoginClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>